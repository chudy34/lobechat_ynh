#!/usr/bin/env bash
set -euo pipefail

repo="lobehub/lobehub"
tag="${1:-}"

if [[ -z "$tag" ]]; then
    echo "Resolving latest GitHub release for $repo..."
    tag="$(curl -fsSL "https://api.github.com/repos/$repo/releases/latest" | node -e '
let data = "";
process.stdin.on("data", chunk => data += chunk);
process.stdin.on("end", () => {
  const release = JSON.parse(data);
  if (!release.tag_name) process.exit(1);
  console.log(release.tag_name);
});
')"
fi

version="${tag#v}"
image="lobehub/lobehub:$version"

echo "Updating package to $repo release $tag..."

perl -0pi -e "s#version = \"[^\"]+\"#version = \"$version~ynh1\"#" manifest.toml
perl -0pi -e "s#image: lobehub/lobehub:[^\\n]+#image: $image#" conf/docker-compose.yml
perl -0pi -e "s#Release: \`[^\`]+\`#Release: \`$tag\`#" README.md
perl -0pi -e "s#Docker image: \`[^\`]+\`#Docker image: \`$image\`#" README.md
perl -0pi -e "s#LobeHub version: \`[^\`]+\`#LobeHub version: \`$version\`#" README.md

echo "Updated to $repo@$tag ($image)."
