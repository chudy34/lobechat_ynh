#!/bin/bash

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

#=================================================
# LOAD SAVED SETTINGS
#=================================================
postgres_password=$(ynh_app_setting_get --app="$app" --key=postgres_password)
rustfs_access_key=$(ynh_app_setting_get --app="$app" --key=rustfs_access_key)
rustfs_secret_key=$(ynh_app_setting_get --app="$app" --key=rustfs_secret_key)
key_vaults_secret=$(ynh_app_setting_get --app="$app" --key=key_vaults_secret)
auth_secret=$(ynh_app_setting_get --app="$app" --key=auth_secret)
searxng_secret=$(ynh_app_setting_get --app="$app" --key=searxng_secret)
admin_email=$(ynh_app_setting_get --app="$app" --key=admin_email)
admin_password=$(ynh_app_setting_get --app="$app" --key=admin_password)

# Ensure all secrets are set (fallback for upgrades from older package revisions)
if [ -z "$postgres_password" ]; then
    postgres_password=$(gen_password)
    ynh_app_setting_set --app="$app" --key=postgres_password --value="$postgres_password"
fi
if [ -z "$rustfs_access_key" ]; then
    rustfs_access_key="lobehubadmin"
    ynh_app_setting_set --app="$app" --key=rustfs_access_key --value="$rustfs_access_key"
fi
if [ -z "$rustfs_secret_key" ]; then
    rustfs_secret_key=$(gen_password)
    ynh_app_setting_set --app="$app" --key=rustfs_secret_key --value="$rustfs_secret_key"
fi
if [ -z "$key_vaults_secret" ]; then
    key_vaults_secret=$(gen_secret)
    ynh_app_setting_set --app="$app" --key=key_vaults_secret --value="$key_vaults_secret"
fi
if [ -z "$auth_secret" ]; then
    auth_secret=$(gen_secret)
    ynh_app_setting_set --app="$app" --key=auth_secret --value="$auth_secret"
fi
if [ -z "$searxng_secret" ]; then
    searxng_secret=$(gen_secret)
    ynh_app_setting_set --app="$app" --key=searxng_secret --value="$searxng_secret"
fi

#=================================================

# STOP SERVICE
#=================================================
ynh_script_progression --message="Stopping LobeHub..." --weight=2
ynh_systemd_action --service_name="$app" --action="stop" --log_path=systemd --timeout=60 || true

#=================================================
# ENSURE DOCKER CE IS INSTALLED
#=================================================
ynh_script_progression --message="Checking Docker CE..." --weight=5
install_docker_ce

#=================================================
# BUILD APP URL
#=================================================
build_app_url

# Remove obsolete empty JWKS override from earlier package revisions.
if [ -f "$install_dir/.env" ]; then
    sed -i '/^JWKS_KEY=/d' "$install_dir/.env"
fi

ynh_script_progression --message="Preparing data directories..." --weight=1
prepare_data_dirs

ynh_script_progression --message="Updating environment config..." --weight=1
write_env_file

ynh_script_progression --message="Updating RustFS bucket policy..." --weight=1
write_bucket_policy

# Ensure SearXNG configuration exists (especially if upgrading from an older version that didn't have it)
if [ ! -f "$data_dir/searxng/settings.yml" ]; then
    ynh_script_progression --message="Creating SearXNG configuration..." --weight=1
    write_searxng_config
fi


#=================================================
# UPDATE DOCKER-COMPOSE
#=================================================
ynh_script_progression --message="Updating Docker Compose configuration..." --weight=1
write_compose_file

#=================================================
# PULL LATEST IMAGES
#=================================================
ynh_script_progression --message="Pulling latest Docker images..." --weight=40

cd "$install_dir"
docker compose --project-name "$app" pull

#=================================================
# UPDATE SYSTEMD + NGINX
#=================================================
ynh_script_progression --message="Updating systemd and nginx..." --weight=2
ynh_add_systemd_config
ynh_add_nginx_config

#=================================================
# RESTART
#=================================================
ynh_script_progression --message="Starting updated LobeHub..." --weight=10
ynh_systemd_action --service_name="$app" --action="start" --log_path=systemd --timeout=300

ynh_script_progression --message="Waiting for LobeHub to be ready..." --weight=5
wait_for_lobehub 600

ynh_script_progression --message="LobeHub upgraded successfully!" --last
