#!/bin/bash

source ../settings/scripts/_common.sh
source /usr/share/yunohost/helpers

#=================================================
# ENSURE DOCKER CE
#=================================================
ynh_script_progression --message="Checking Docker CE..." --weight=10
install_docker_ce

#=================================================
# RESTORE FILES
#=================================================
ynh_script_progression --message="Restoring install dir..." --weight=5
ynh_restore_file --origin_path="$install_dir"

ynh_script_progression --message="Restoring data..." --weight=20
ynh_restore_file --origin_path="$data_dir"

ynh_script_progression --message="Repairing data permissions..." --weight=2
prepare_data_dirs

#=================================================
# PULL IMAGES & START
#=================================================
ynh_script_progression --message="Pulling Docker images..." --weight=40

cd "$install_dir"
docker compose --project-name "$app" pull

ynh_script_progression --message="Restoring systemd and nginx..." --weight=2
ynh_restore_file --origin_path="/etc/systemd/system/$app.service"
systemctl daemon-reload
ynh_restore_file --origin_path="/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_script_progression --message="Starting restored LobeHub..." --weight=10
ynh_systemd_action --service_name="$app" --action="start" --log_path=systemd --timeout=300

ynh_script_progression --message="Waiting for LobeHub to be ready..." --weight=5
wait_for_lobehub 600

ynh_script_progression --message="Restore complete!" --last
