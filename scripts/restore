#!/bin/bash

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

#=================================================
# ENSURE DOCKER CE
#=================================================
ynh_script_progression --message="Checking Docker CE..." --weight=10
install_docker_ce

#=================================================
# RESTORE FILES
#=================================================
ynh_script_progression --message="Restoring install dir..." --weight=5
ynh_restore_file --origin_path="$install_dir"

ynh_script_progression --message="Restoring data..." --weight=20
ynh_restore_file --origin_path="$data_dir"

ynh_script_progression --message="Repairing data permissions..." --weight=2
prepare_data_dirs

#=================================================
# PULL IMAGES & START
#=================================================
ynh_script_progression --message="Pulling Docker images..." --weight=40

cd "$install_dir"
docker compose --project-name "$app" pull

ynh_script_progression --message="Restoring systemd and nginx..." --weight=2
ynh_restore_file --origin_path="/etc/systemd/system/$app.service"
systemctl daemon-reload
ynh_restore_file --origin_path="/etc/nginx/conf.d/$domain.d/$app.conf"

ynh_script_progression --message="Starting restored LobeHub..." --weight=10
# Use "restart" instead of "start": with Type=oneshot + RemainAfterExit=yes,
# systemd keeps the unit in "active (exited)" state after a previous run, so
# "start" becomes a no-op. "restart" forces ExecStop + ExecStart again.
# We call systemctl directly (not ynh_systemd_action) so that a non-zero exit
# from "docker compose up -d" (e.g. a dependency still warming up) does NOT
# abort the restore before wait_for_lobehub can collect diagnostics.
systemctl restart "$app" || true
sleep 5

# Wait for PostgreSQL to be ready, then restore database dump
ynh_script_progression --message="Waiting for PostgreSQL..." --weight=3
local pg_ready=0
for i in $(seq 1 30); do
    if docker compose --project-name "$app" --file "$install_dir/docker-compose.yml" \
        exec -T postgresql pg_isready -U postgres >/dev/null 2>&1; then
        pg_ready=1
        break
    fi
    sleep 2
done

if [ "$pg_ready" = "1" ] && [ -f "$data_dir/backups/postgres_dump.sql" ]; then
    restore_postgres "$data_dir/backups/postgres_dump.sql"
fi

ynh_script_progression --message="Waiting for LobeHub to be ready..." --weight=5
wait_for_lobehub 900

ynh_script_progression --message="Restore complete!" --last
