#!/bin/bash

source "$(dirname "$0")/_common.sh"
source /usr/share/yunohost/helpers

#=================================================
# RETRIEVE INSTALL ARGS
#=================================================
admin_email="$YNH_APP_ARG_ADMIN_EMAIL"
admin_password="$YNH_APP_ARG_ADMIN_PASSWORD"

#=================================================
# INSTALL DOCKER CE (with Compose v2)
#=================================================
ynh_script_progression --message="Installing Docker CE with Compose v2..." --weight=15
install_docker_ce

#=================================================
# GENERATE ALL SECRETS
#=================================================
ynh_script_progression --message="Generating cryptographic secrets..." --weight=1

postgres_password=$(gen_password)
rustfs_access_key="lobehubadmin"
rustfs_secret_key=$(gen_password)
key_vaults_secret=$(gen_secret)
auth_secret=$(gen_secret)
searxng_secret=$(gen_secret)

# Persist all secrets
ynh_app_setting_set --app="$app" --key=postgres_password  --value="$postgres_password"
ynh_app_setting_set --app="$app" --key=rustfs_access_key  --value="$rustfs_access_key"
ynh_app_setting_set --app="$app" --key=rustfs_secret_key  --value="$rustfs_secret_key"
ynh_app_setting_set --app="$app" --key=key_vaults_secret  --value="$key_vaults_secret"
ynh_app_setting_set --app="$app" --key=auth_secret        --value="$auth_secret"
ynh_app_setting_set --app="$app" --key=searxng_secret     --value="$searxng_secret"
ynh_app_setting_set --app="$app" --key=admin_email        --value="$admin_email"
ynh_app_setting_set --app="$app" --key=admin_password     --value="$admin_password"

#=================================================
# PREPARE DATA DIRECTORIES
#=================================================
ynh_script_progression --message="Preparing data directories..." --weight=1
prepare_data_dirs
# Wipe stale PostgreSQL data if a previous ParadeDB install left an
# incompatible postgresql.conf (pg_search preload library).
clean_postgres_data_dir

#=================================================
# SEARXNG SETTINGS
#=================================================
ynh_script_progression --message="Configuring SearXNG..." --weight=1
write_searxng_config

#=================================================
# RUSTFS BUCKET POLICY
#=================================================
ynh_script_progression --message="Preparing RustFS bucket policy..." --weight=1
write_bucket_policy

#=================================================
# BUILD APP URL
#=================================================
build_app_url

#=================================================
# GENERATE .env
#=================================================
ynh_script_progression --message="Writing environment config..." --weight=1
write_env_file

#=================================================
# DEPLOY DOCKER-COMPOSE
#=================================================
ynh_script_progression --message="Deploying Docker Compose configuration..." --weight=1
write_compose_file

#=================================================
# PRE-PULL DOCKER IMAGES
#=================================================
ynh_script_progression --message="Pulling Docker images (this may take 5-10 minutes)..." --weight=50

cd "$install_dir"
docker compose --project-name "$app" pull

#=================================================
# SYSTEMD + NGINX
#=================================================
ynh_script_progression --message="Configuring systemd service..." --weight=1
ynh_add_systemd_config

ynh_script_progression --message="Configuring NGINX..." --weight=1
ynh_add_nginx_config

#=================================================
# START STACK
#=================================================
ynh_script_progression --message="Starting LobeHub stack (first start may take up to 10 minutes)..." --weight=15
# Use "restart" instead of "start": with Type=oneshot + RemainAfterExit=yes,
# systemd keeps the unit in "active (exited)" state after a previous run, so
# "start" becomes a no-op. "restart" forces ExecStop + ExecStart again.
# We call systemctl directly (not ynh_systemd_action) so that a non-zero exit
# from "docker compose up -d" (e.g. a dependency still warming up) does NOT
# abort the install before wait_for_lobehub can collect diagnostics.
systemctl restart "$app" || true
# Give compose a moment to spin up containers before polling
sleep 5

#=================================================
# HEALTH CHECK
#=================================================
ynh_script_progression --message="Waiting for LobeHub to be ready..." --weight=5
wait_for_lobehub 900

#=================================================
# DONE
#=================================================
ynh_script_progression --message="LobeHub installed successfully! URL: ${APP_URL} - Admin: ${admin_email}" --last
