#!/bin/bash

source _common.sh
source /usr/share/yunohost/helpers

ynh_script_progression --message="Stopping stack for consistent backup..." --weight=2
ynh_systemd_action --service_name="$app" --action="stop" --log_path=systemd --timeout=60

#=================================================
# BACKUP FILES
#=================================================
ynh_script_progression --message="Backing up install dir..." --weight=5
ynh_backup --src_path="$install_dir"

ynh_script_progression --message="Backing up data..." --weight=20
ynh_backup --src_path="$data_dir"

#=================================================
# RESTART AFTER BACKUP
#=================================================
ynh_systemd_action --service_name="$app" --action="start" --log_path=systemd --timeout=300

ynh_script_progression --message="Backup complete." --last
